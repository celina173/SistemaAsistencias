<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nueva Inscripción - Sistema de Asistencias</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="style.css">
</head>
<body class="agregar-page">

    <header class="top-header">
        <div class="menu-icon">
            <div class="bar"></div>
            <div class="bar"></div>
            <div class="bar"></div>
        </div>
        <div class="header-title">
            <span class="title-small">INSTITUTO N° 124</span>
            <h1 class="title-large">SISTEMA DE ASISTENCIAS</h1>
        </div>
        <div class="header-logo">
            <img src="img/logo.png" alt="IS 124" class="logo-img">
        </div>
    </header>

    <nav class="sidebar" id="sidebarMenu">
        <ul class="sidebar-links">
            <li class="active"><a href="inicio.html">Inicio</a></li>
            <li><a href="asistencia-global.html">Calendario</a></li>
            <li class="menu-divider"></li>
            <li class="logout"><a href="index.html">Cerrar Sesión</a></li>
        </ul>
    </nav>

    <div class="header-divider"></div>

    <div class="info-banner">
        <div class="info-col-left"><p class="info-bold">INSCRIPCIONES</p></div>
        <div class="info-col-right"><p class="info-bold">ADMINISTRADOR</p></div>
    </div>

    <div class="page-title-container">
        <h2 class="page-main-title">Nueva Inscripción</h2>
    </div>

    <main class="main-container-form">
        <div class="form-card">
            <form id="formInscripcion" class="form-grid">

                <div class="input-field" style="grid-column: span 2;">
                    <label for="alumno">Seleccionar Alumno</label>
                    <input type="text" id="alumno" name="alumno" list="lista-alumnos" placeholder="Escribí para buscar alumno..." required autocomplete="off">
                    <datalist id="lista-alumnos">
                        <option value="Albornoz Celina (39.123.456)"></option>
                        <option value="Medina Roselen (44.987.654)"></option>
                        <option value="Gomez Juan (40.111.222)"></option>
                        <option value="Perez Maria (42.333.444)"></option>
                    </datalist>
                </div>

                <div class="input-field">
                    <label for="carrera">Carrera</label>
                    <input type="text" id="carrera" name="carrera" list="lista-carreras" placeholder="Escribí para buscar carrera..." required autocomplete="off">
                    <datalist id="lista-carreras">
                        <option value="Tec. Sup. en Desarrollo de Software"></option>
                        <option value="Tec. Sup. en Análisis de Sistemas"></option>
                        <option value="Tec. Sup. en Higiene y Seguridad"></option>
                    </datalist>
                </div>

                <div class="input-field">
                    <label for="materia">Materia</label>
                    <input type="text" id="materia" name="materia" list="lista-materias" placeholder="Escribí para buscar materia..." required autocomplete="off">
                    <datalist id="lista-materias">
                        <option value="Programación I"></option>
                        <option value="Base de Datos"></option>
                        <option value="Sistemas Operativos"></option>
                        <option value="Práctica Profesionalizante"></option>
                    </datalist>
                </div>

                <div class="form-buttons" style="grid-column: span 2;">
                    <button type="button" class="btn-cancel" onclick="window.location.href='inscripcion-materias.html'">Cancelar</button>
                    <button type="submit" class="btn-save">Confirmar Inscripción</button>
                </div>
            </form>
        </div>
    </main>

    <script src="script.js"></script>
</body>
</html>