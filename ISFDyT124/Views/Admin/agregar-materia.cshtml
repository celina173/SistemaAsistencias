<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agregar Materia - Sistema de Asistencias</title>
    <link rel="stylesheet" href="style.css">
</head>
<body class="agregar-page">
    <header class="top-header">
        <div class="menu-icon">
            <div class="bar"></div>
            <div class="bar"></div>
            <div class="bar"></div>
        </div>

        <div class="header-title">
            <span class="title-small">INSTITUTO N° 124</span>
            <h1 class="title-large">SISTEMA DE ASISTENCIAS</h1>
        </div>

        <div class="header-logo">
            <img src="img/logo.png" alt="IS 124" class="logo-img">
        </div>
    </header>

    <nav class="sidebar" id="sidebarMenu">
        <ul class="sidebar-links">
            <li class="active"><a href="inicio.html">Inicio</a></li>
            <li><a href="asistencia-global.html">Calendario</a></li>
            <li class="menu-divider"></li>
            <li class="logout"><a href="index.html">Cerrar Sesión</a></li>
        </ul>
    </nav>

    <div class="header-divider"></div>

    <div class="info-banner">
        <div class="info-col-left">
            <p class="info-bold">PANEL DE CONTROL</p>
        </div>
        <div class="info-col-right">
            <p class="info-bold">ADMINISTRADOR</p>
        </div>
    </div>

    <div class="page-title-container">
        <h2 class="page-main-title">Agregar Materia</h2>
    </div>

    <main class="main-container-form">
        <div class="form-card">
            <form id="formAgregarMateria" class="form-grid">

                <div class="input-field">
                    <label for="nombreMateria">Nombre de la Materia</label>
                    <input type="text" id="nombreMateria" name="nombreMateria" placeholder="Ej: Programación III" required autocomplete="off">
                </div>

                <div class="input-field">
                    <label for="codigoMateria">Código de Materia</label>
                    <input type="text" id="codigoMateria" name="codigoMateria" placeholder="Ej: PROG3" required autocomplete="off">
                </div>

                <div class="input-field">
                    <label for="carreraMateria">Carrera</label>
                    <input type="text" id="carreraMateria" name="carreraMateria" list="lista-carreras" placeholder="Escribí para buscar carrera..." required autocomplete="off">
                    <datalist id="lista-carreras">
                        <option value="Tec. Sup. en Desarrollo de Software"></option>
                        <option value="Tec. Sup. en Análisis de Sistemas"></option>
                        <option value="Tec. Sup. en Higiene y Seguridad"></option>
                    </datalist>
                </div>

                <div class="input-field">
                    <label for="regimenMateria">Año / Cuatrimestre</label>
                    <input type="text" id="regimenMateria" name="regimenMateria" placeholder="Ej: 1er Año - 2do Cuat." required autocomplete="off">
                </div>

                <div class="input-field" style="grid-column: span 2;">
                    <label for="cargaHoraria">Carga Horaria Semanal (Horas)</label>
                    <input type="number" id="cargaHoraria" name="cargaHoraria" placeholder="Ej: 4" required autocomplete="off">
                </div>

                <div class="form-buttons" style="grid-column: span 2;">
                    <button type="button" class="btn-cancel" onclick="window.location.href='gestion-materias.html'">Cancelar</button>
                    <button type="submit" class="btn-save">Guardar Materia</button>
                </div>

            </form>
        </div>
    </main>

    <script src="script.js"></script>
</body>
</html>