@{
    ViewData["Title"] = "Panel de Control";
    ViewData["BodyClass"] = "admin-page";
}

<div class="info-banner">
    <div class="info-col-left">
        <p class="info-bold">PANEL DE CONTROL</p>
    </div>
    <div class="info-col-right">
        <p class="info-bold">ADMINISTRADOR</p>
    </div>
</div>

<main class="main-container-admin">
    <div class="cards-grid">
        <a asp-controller="Admin" asp-action="UsuariosABM" style="text-decoration: none; color: inherit;">
            <div class="admin-card" id="card-usuarios">
                <i class="bi bi-people card-icon-vector"></i>
                <h3>Usuarios</h3>
            </div>
        </a>

        <a asp-controller="Materias" asp-action="Index" style="text-decoration: none; color: inherit;">
            <div class="admin-card" id="card-materias">
                <i class="bi bi-book card-icon-vector"></i>
                <h3>Materias</h3>
            </div>
        </a>

        <a asp-controller="Carreras" asp-action="Index" style="text-decoration: none; color: inherit;">
            <div class="admin-card" id="card-carreras">
                <i class="bi bi-mortarboard card-icon-vector"></i>
                <h3>Carreras</h3>
            </div>
        </a>

        <a asp-controller="Profesor" asp-action="Index" style="text-decoration: none; color: inherit;">
            <div class="admin-card" id="card-docentes">
                <i class="bi bi-person-workspace card-icon-vector"></i>
                <h3>Docentes</h3>
            </div>
        </a>
    </div>
</main>
