<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modificar Carrera - Sistema de Asistencias</title>
    <link rel="stylesheet" href="style.css">
</head>
<body class="agregar-page">

    <header class="top-header">
        <div class="menu-icon">
            <div class="bar"></div>
            <div class="bar"></div>
            <div class="bar"></div>
        </div>

        <div class="header-title">
            <span class="title-small">INSTITUTO N° 124</span>
            <h1 class="title-large">SISTEMA DE ASISTENCIAS</h1>
        </div>

        <div class="header-logo">
            <img src="img/logo.png" alt="IS 124" class="logo-img">
        </div>
    </header>

    <nav class="sidebar" id="sidebarMenu">
        <ul class="sidebar-links">
            <li><a href="inicio-admin.html">Inicio</a></li>
            <li><a href="asistencia-global.html">Calendario</a></li>
            <li class="menu-divider"></li>
            <li><a href="gestion-carreras.html">Volver a Gestión</a></li>
            <li class="logout"><a href="index.html">Cerrar Sesión</a></li>
        </ul>
    </nav>

    <div class="header-divider"></div>

    <div class="info-banner">
        <div class="info-col-left">
            <p class="info-bold">PANEL DE CONTROL</p>
        </div>
        <div class="info-col-right">
            <p class="info-bold">ADMINISTRADOR</p>
        </div>
    </div>

    <div class="page-title-container">
        <h2 class="page-main-title">Modificar Carrera</h2>
    </div>

    <main class="main-container-form">
        <div class="form-card">
            <form id="formModificarCarrera" class="form-grid">

                <div class="input-field">
                    <label for="nombreCarrera">Nombre de la Carrera</label>
                    <input type="text" id="nombreCarrera" name="nombreCarrera" value="Tec. Sup. en Desarrollo de Software" placeholder="Ej: Desarrollo de Software" required autocomplete="off">
                </div>

                <div class="input-field">
                    <label for="codigoCarrera">Código / Resolución</label>
                    <input type="text" id="codigoCarrera" name="codigoCarrera" value="Res. 3812/16" placeholder="Ej: Res. 123/24" required autocomplete="off">
                </div>

                <div class="input-field">
                    <label for="duracionCarrera">Duración (en años)</label>
                    <input type="text" id="duracionCarrera" name="duracionCarrera" value="3 Años" placeholder="Ej: 3 años" required autocomplete="off">
                </div>

                <div class="input-field">
                    <label for="tituloCarrera">Título que Otorga</label>
                    <input type="text" id="tituloCarrera" name="tituloCarrera" value="Técnico Superior en Desarrollo de Software" placeholder="Ej: Técnico Superior en..." required autocomplete="off">
                </div>

                <div class="input-field" style="grid-column: span 2;">
                    <label for="modalidadCarrera">Modalidad</label>
                    <input type="text" id="modalidadCarrera" name="modalidadCarrera" value="Presencial" list="lista-modalidades" placeholder="Escribí para buscar modalidad..." required autocomplete="off">
                    <datalist id="lista-modalidades">
                        <option value="Presencial"></option>
                        <option value="Semipresencial"></option>
                        <option value="A Distancia / Virtual"></option>
                    </datalist>
                </div>

                <div class="form-buttons" style="grid-column: span 2;">
                    <button type="button" class="btn-cancel" onclick="window.location.href='gestion-carreras.html'">Cancelar</button>
                    <button type="submit" class="btn-save">Actualizar Carrera</button>
                </div>

            </form>
        </div>
    </main>

    <script src="script.js"></script>
</body>
</html>