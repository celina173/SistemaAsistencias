<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Materias - Sistema de Asistencias</title>
    <link rel="stylesheet" href="style.css">
</head>
<body class="gestion-page">
    <header class="top-header">
        <div class="menu-icon">
            <div class="bar"></div>
            <div class="bar"></div>
            <div class="bar"></div>
        </div>

        <div class="header-title">
            <span class="title-small">INSTITUTO N° 124</span>
            <h1 class="title-large">SISTEMA DE ASISTENCIAS</h1>
        </div>

        <div class="header-logo">
            <img src="img/logo.png" alt="IS 124" class="logo-img">
        </div>
    </header>

    <nav class="sidebar" id="sidebarMenu">
        <ul class="sidebar-links">
            <li class="active"><a href="inicio.html">Inicio</a></li>
            <li><a href="asistencia-global.html">Calendario</a></li>
            <li class="logout"><a href="index.html">Cerrar Sesión</a></li>
        </ul>
    </nav>

    <div class="header-divider"></div>

    <div class="info-banner">
        <div class="info-col-left">
            <p class="info-bold">PANEL DE CONTROL</p>
        </div>
        <div class="info-col-right">
            <p class="info-bold">ADMINISTRADOR</p>
        </div>
    </div>

    <div class="page-title-container">
        <h2 class="page-main-title">Gestión Materias</h2>
    </div>

    <main class="main-container-global">

        <div class="toolbar-container">
            <div class="search-box">
                <input type="text" id="inputBusqueda" placeholder="Buscar materia..." autocomplete="off" data-lpignore="true">
                <button class="btn-search" id="btnBuscar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                </button>
            </div>

            <div class="add-btn-container">
                <button class="btn-add" id="btnAgregar" onclick="window.location.href='agregar-materia.html'">+</button>
            </div>
        </div>

        <div class="global-table-container">
            <table class="global-table crud-materias">
                <thead>
                    <tr>
                        <th>CÓDIGO</th>
                        <th class="align-left">NOMBRE DE LA MATERIA</th>
                        <th class="align-left">CARRERA</th>
                        <th>AÑO / CUAT.</th>
                        <th>ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>DS-301</td>
                        <td class="align-left">Programación Avanzada</td>
                        <td class="align-left">Tec. Sup. en Desarrollo de Software</td>
                        <td>3er Año - 1er Cuat.</td>
                        <td class="action-cell">
                            <button class="icon-btn btn-edit" title="Editar" onclick="window.location.href='modificar-materia.html'">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"></path></svg>
                            </button>
                        </td>
                    </tr>
                    <tr>
                        <td>DS-302</td>
                        <td class="align-left">Bases de Datos II</td>
                        <td class="align-left">Tec. Sup. en Desarrollo de Software</td>
                        <td>3er Año - 1er Cuat.</td>
                        <td class="action-cell">
                            <button class="icon-btn btn-edit" title="Editar" onclick="window.location.href='modificar-materia.html'">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"></path></svg>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>

    <script src="script.js"></script>
</body>
</html>