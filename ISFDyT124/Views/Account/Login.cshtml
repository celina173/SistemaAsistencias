@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login IS 124</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
</head>
<body class="login-page">
    <div class="login-card">
        <div class="logo-container">
            <img src="~/images/logo.png" alt="IS 124 Logo" class="logo-img">
        </div>

        <form id="loginForm" method="post" action="/Account/Login">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true)
            <div class="input-group">
                <label for="usuario">Usuario</label>
                <input type="text" id="usuario" name="usuario" placeholder="Ingresá tu usuario" required>
            </div>

            <div class="input-group">
                <label for="contrasena">Contraseña</label>
                <input type="password" id="contrasena" name="contrasena" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn-submit" aria-label="Ingresar">
                <span class="arrow">➔</span>
            </button>
        </form>

        <div class="link-container">
            <a href="recupero-contraseña.html" class="forgot-password">Olvidé mi contraseña</a>
        </div>
    </div>

    <script src="~/js/script.js"></script>
</body>
</html>